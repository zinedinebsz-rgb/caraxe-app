{
  "headers": [
    {
      "source": "/landing.html",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/offre-formation-ecom.html",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/offre-creation-boutique.html",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/merci.html",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sourcing.html",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/sourcing.html"
    },
    {
      "source": "/ecommerce.html",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/ecommerce.html"
    },
    {
      "source": "/vehicules.html",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/vehicules.html"
    },
    {
      "source": "/offre-formation-ecom.html",
      "destination": "/offre-formation-ecom.html"
    },
    {
      "source": "/offre-creation-boutique.html",
      "destination": "/offre-creation-boutique.html"
    },
    {
      "source": "/merci.html",
      "destination": "/merci.html"
    },
    {
      "source": "/rendez-vous.html",
      "destination": "/rendez-vous.html"
    },
    {
      "source": "/landing.html",
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
