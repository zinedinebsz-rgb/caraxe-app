{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "X-XSS-Protection", "value": "0" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://www.google-analytics.com; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://player.vimeo.com; worker-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'self' https://*.supabase.co" }
      ]
    },
    {
      "source": "/landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/landing-v10.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60" }
      ]
    },
    {
      "source": "/offre-formation-ecom.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/offre-creation-boutique.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/merci.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sourcing.html",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/sourcing.html"
    },
    {
      "source": "/ecommerce.html",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/ecommerce.html"
    },
    {
      "source": "/vehicules.html",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/vehicules.html"
    },
    { "source": "/offre-formation-ecom.html", "destination": "/offre-formation-ecom.html" },
    { "source": "/offre-creation-boutique.html", "destination": "/offre-creation-boutique.html" },
    { "source": "/merci.html", "destination": "/merci.html" },
    { "source": "/rendez-vous.html", "destination": "/rendez-vous.html" },
    { "source": "/landing.html", "destination": "/landing.html" },
    { "source": "/landing-v10.html", "destination": "/landing-v10.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/formation/:path*", "destination": "/formation/:path*" },
    { "source": "/programme-formation-caraxes.pdf", "destination": "/programme-formation-caraxes.pdf" },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "caraxes.fr" }],
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
